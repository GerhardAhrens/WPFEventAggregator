<UserControl
    x:Class="WPFEventAggregator.Beispiele.SettingsUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFEventAggregator.Beispiele"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <!--  Inhalte zum UserControl  -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Border Background="#FAFAFB" CornerRadius="5">
            <Grid
                Margin="10"
                ColumnDefinitions="120, *"
                RowDefinitions="40,25,25,25">
                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,10"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,2">
                    <TextBlock
                        HorizontalAlignment="Left"
                        FontSize="16"
                        FontWeight="Bold">
                        <Run Text="Einstellungen zu" />
                        <Run Text="{Binding Path=WindowTitel, FallbackValue=~WindowTitel}" />
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
