<base:WindowBase
    x:Class="WPFEventAggregator.Beispiele.ListDialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:System.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFEventAggregator.Beispiele"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Path=WindowTitel, FallbackValue=~WindowTitel}"
    Width="800"
    Height="450"
    ResizeMode="CanMinimize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid>
        <!--  Inhalte zum Window  -->
        <DataGrid
            Margin="20"
            AutoGenerateColumns="True"
            IsReadOnly="True"
            ItemsSource="{Binding Path=DemoTabelle, FallbackValue={x:Null}}" />
    </Grid>
</base:WindowBase>
