<base:WindowBase
    x:Class="WPFEventAggregator.Beispiele.ListDialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:System.Windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFEventAggregator.Beispiele"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Path=WindowTitel, FallbackValue=~WindowTitel}"
    Width="800"
    Height="450"
    ResizeMode="CanMinimize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid>
        <!--  Inhalte zum Window  -->
        <TextBlock
            Width="600"
            Height="300"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="14"
            FontWeight="Medium"
            Text="{Binding Path=DemoText, FallbackValue=~Dialog Fenster}"
            TextWrapping="WrapWithOverflow" />
    </Grid>
</base:WindowBase>
